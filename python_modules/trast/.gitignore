*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Logs and output files
logs/
*.log
backups/
*.xlsx
*.csv
session_*.pkl
working_proxies.json
learning_data.json

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Selenium WebDriver cache
.wdm/

# Test outputs
test_output/
test_results/

# Configuration files with sensitive data
.env
config_local.py
secrets.json
